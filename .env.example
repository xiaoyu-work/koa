# LLM (set the one matching your provider)
OPENAI_API_KEY=               # also used for embedding if provider is not openai/azure
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=        # e.g. https://xxx.openai.azure.com/
DASHSCOPE_API_KEY=
GOOGLE_API_KEY=

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/koa

# Supabase (Storage)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# API Authentication (if not set, all endpoints are unauthenticated — dev mode only)
KOA_API_KEY=

# Credential encryption key (AES-256; when set, OAuth tokens are encrypted at rest)
KOA_CREDENTIAL_KEY=

# Service-to-service authentication (for internal credential APIs)
KOA_SERVICE_KEY=change-me-in-production

# KoiAI callback URL (for persisting chat history after stream completes)
KOIAI_CALLBACK_URL=http://localhost:8001/api/internal/stream-result

# Agent Services
WEATHER_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
JINA_API_KEY=                  # https://jina.ai/reader/ — web content extraction
TRACK17_API_KEY=
NOTION_API_KEY=
COMPOSIO_API_KEY=              # https://app.composio.dev/settings

# OAuth Apps (for Google & Microsoft sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

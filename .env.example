# ===========================================================================
# Koa Environment Variables
# ===========================================================================
# Copy to .env and fill in the values you need.
# Only DATABASE_URL and one LLM API key are required to get started.
# ===========================================================================

# ---------------------------------------------------------------------------
# Database (required)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:pass@localhost:5432/koa

# ---------------------------------------------------------------------------
# LLM API Key (required — set the one matching your config.yaml provider)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=        # e.g. https://xxx.openai.azure.com/
DASHSCOPE_API_KEY=
GOOGLE_API_KEY=               # for Gemini

# ---------------------------------------------------------------------------
# Koa Server Settings
# ---------------------------------------------------------------------------
KOA_API_KEY=                  # API auth — if not set, endpoints are unauthenticated (dev mode)
KOA_CREDENTIAL_KEY=           # AES-256 encryption for OAuth tokens at rest
KOA_SERVICE_KEY=change-me-in-production   # internal service-to-service auth

# ---------------------------------------------------------------------------
# OAuth Apps (for `koa connect` — connect user accounts)
# ---------------------------------------------------------------------------
# Google (Gmail, Calendar, Tasks, Drive) — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft (Outlook, Calendar, To Do, OneDrive) — https://portal.azure.com/
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Todoist — https://developer.todoist.com/
# TODOIST_CLIENT_ID=
# TODOIST_CLIENT_SECRET=

# Notion — https://www.notion.so/my-integrations
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=

# Philips Hue — https://developers.meethue.com/
# HUE_CLIENT_ID=
# HUE_CLIENT_SECRET=

# Sonos — https://developer.sonos.com/
# SONOS_CLIENT_ID=
# SONOS_CLIENT_SECRET=

# Composio (Slack, GitHub, Spotify, Discord, etc.) — https://app.composio.dev/
# COMPOSIO_API_KEY=

# ---------------------------------------------------------------------------
# Agent API Keys (optional — only for agents you want to use)
# ---------------------------------------------------------------------------
# WEATHER_API_KEY=              # https://www.weatherapi.com/
# GOOGLE_MAPS_API_KEY=          # https://console.cloud.google.com/
# GOOGLE_SEARCH_API_KEY=        # https://console.cloud.google.com/
# GOOGLE_SEARCH_ENGINE_ID=      # https://programmablesearchengine.google.com/
# JINA_API_KEY=                 # https://jina.ai/reader/
# TRACK17_API_KEY=              # https://api.17track.net/
# AMADEUS_API_KEY=              # https://developers.amadeus.com/
# AMADEUS_API_SECRET=

# ---------------------------------------------------------------------------
# Storage (optional)
# ---------------------------------------------------------------------------
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Callbacks (optional)
# ---------------------------------------------------------------------------
# KOIAI_CALLBACK_URL=http://localhost:8001/api/internal/stream-result

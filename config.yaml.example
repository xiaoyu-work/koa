# ===========================================================================
# Koa Configuration
# ===========================================================================
# ${VAR} references are replaced with environment variable values.
# Copy this file to config.yaml and edit as needed.
# ===========================================================================

# ---------------------------------------------------------------------------
# Database (required)
# ---------------------------------------------------------------------------
# PostgreSQL connection URL. Set DATABASE_URL in .env or inline here.
database: ${DATABASE_URL}

# ---------------------------------------------------------------------------
# LLM Provider (required)
# ---------------------------------------------------------------------------
# Supported: openai, anthropic, azure, dashscope, gemini, ollama
llm:
  provider: openai
  model: gpt-4o
  # api_key: ${OPENAI_API_KEY}          # defaults to provider's env var
  # base_url: https://your-endpoint/    # required for Azure

# ---------------------------------------------------------------------------
# Embedding (required for memory)
# ---------------------------------------------------------------------------
# Used for long-term memory (semantic search over past conversations).
embedding:
  provider: openai
  model: text-embedding-3-small
  # api_key: ${OPENAI_API_KEY}          # defaults to llm.api_key if omitted
  # base_url: https://your-endpoint/    # Azure only
  # api_version: '2024-02-01'           # Azure only

# ---------------------------------------------------------------------------
# System Prompt (optional)
# ---------------------------------------------------------------------------
# Customize the assistant personality.
#
# system_prompt: |
#   Your name is Jarvis. You speak in a warm, butler-like tone.
#
# system_prompt_mode: append    # "append" (default) or "override"
#   append   — added after the built-in Koa prompt
#   override — replaces the default preamble ("You are Koa...")

# ---------------------------------------------------------------------------
# Supabase Storage (optional)
# ---------------------------------------------------------------------------
# For file uploads (receipts, user documents, etc.)
#
# supabase:
#   url: ${SUPABASE_URL}
#   service_role_key: ${SUPABASE_SERVICE_ROLE_KEY}
#   storage_bucket: koa-files

# ===========================================================================
# Account Connections (OAuth)
# ===========================================================================
# Connect accounts with: koa connect <service>
# These require OAuth app credentials in your .env file.
#
# ┌──────────────┬──────────────────────────────┬──────────────────────────────┐
# │ Service      │ What it enables              │ .env keys needed             │
# ├──────────────┼──────────────────────────────┼──────────────────────────────┤
# │ google       │ Gmail, Calendar, Tasks,      │ GOOGLE_CLIENT_ID             │
# │              │ Drive                        │ GOOGLE_CLIENT_SECRET         │
# ├──────────────┼──────────────────────────────┼──────────────────────────────┤
# │ microsoft    │ Outlook, Calendar, To Do,    │ MICROSOFT_CLIENT_ID          │
# │              │ OneDrive                     │ MICROSOFT_CLIENT_SECRET      │
# │              │                              │ MICROSOFT_TENANT_ID          │
# ├──────────────┼──────────────────────────────┼──────────────────────────────┤
# │ todoist      │ Todoist tasks                │ TODOIST_CLIENT_ID            │
# │              │                              │ TODOIST_CLIENT_SECRET        │
# ├──────────────┼──────────────────────────────┼──────────────────────────────┤
# │ notion       │ Notion workspace             │ NOTION_CLIENT_ID             │
# │              │                              │ NOTION_CLIENT_SECRET         │
# ├──────────────┼──────────────────────────────┼──────────────────────────────┤
# │ dropbox      │ Dropbox file storage         │ (uses Google/Microsoft app)  │
# ├──────────────┼──────────────────────────────┼──────────────────────────────┤
# │ hue          │ Philips Hue smart lights     │ HUE_CLIENT_ID                │
# │              │                              │ HUE_CLIENT_SECRET            │
# ├──────────────┼──────────────────────────────┼──────────────────────────────┤
# │ sonos        │ Sonos speakers               │ SONOS_CLIENT_ID              │
# │              │                              │ SONOS_CLIENT_SECRET          │
# ├──────────────┼──────────────────────────────┼──────────────────────────────┤
# │ slack,       │ Via Composio platform         │ COMPOSIO_API_KEY             │
# │ github,      │                              │                              │
# │ spotify, ... │                              │                              │
# └──────────────┴──────────────────────────────┴──────────────────────────────┘

# ===========================================================================
# Agent API Keys (optional — only for agents you want to use)
# ===========================================================================
# These go in your .env file, not here. Listed for reference.
#
# ┌──────────────────────────┬──────────────────────────────────────────────┐
# │ .env Variable            │ Agent / Feature                              │
# ├──────────────────────────┼──────────────────────────────────────────────┤
# │ WEATHER_API_KEY          │ Weather forecasts                            │
# │ GOOGLE_MAPS_API_KEY      │ Maps, directions, nearby places              │
# │ GOOGLE_SEARCH_API_KEY    │ Web search                                   │
# │ GOOGLE_SEARCH_ENGINE_ID  │ Web search (Programmable Search Engine ID)   │
# │ JINA_API_KEY             │ Flight/hotel search (Jina Reader)            │
# │ TRACK17_API_KEY          │ Package tracking (17TRACK)                   │
# │ COMPOSIO_API_KEY         │ Slack, GitHub, Spotify, Discord, etc.        │
# │ AMADEUS_API_KEY          │ Flight search (Amadeus)                      │
# │ AMADEUS_API_SECRET       │ Flight search (Amadeus)                      │
# └──────────────────────────┴──────────────────────────────────────────────┘

# ===========================================================================
# Model Routing (optional — route requests to different LLMs by complexity)
# ===========================================================================
# When enabled, a classifier scores each request (1-100) and selects
# the best provider. Simple tasks → cheap models, complex tasks → strong.
#
# llm_providers:
#   strong:
#     provider: anthropic
#     model: claude-sonnet-4-20250514
#     api_key: ${ANTHROPIC_API_KEY}
#   fast:
#     provider: openai
#     model: gpt-4o-mini
#     api_key: ${OPENAI_API_KEY}
#   cheap:
#     provider: dashscope
#     model: deepseek-chat
#     api_key: ${DEEPSEEK_API_KEY}
#
# model_routing:
#   enabled: true
#   classifier_provider: fast
#   default_provider: fast
#   rules:
#     - score_range: [1, 30]
#       provider: cheap
#     - score_range: [31, 70]
#       provider: fast
#     - score_range: [71, 100]
#       provider: strong

# ===========================================================================
# MCP Servers (optional — Model Context Protocol tool servers)
# ===========================================================================
# Each entry defines an MCP server whose tools become available to agents.
# Supported transports: stdio, sse, streamable_http
#
# mcp_servers:
#   invokit:
#     transport: streamable_http
#     url: https://api.invok.it/mcp
#     headers:
#       Authorization: "Bearer ${INVOKIT_API_KEY:-}"
#     timeout: 30
#
#   filesystem:
#     transport: stdio
#     command: npx
#     args: ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/dir"]

# ===========================================================================
# Callbacks (optional — webhook notifications)
# ===========================================================================
# Koa POSTs notifications here (e.g. important emails, trigger results).
#
# callbacks:
#   notify_url: http://localhost:8001/webhook/koa/callback
